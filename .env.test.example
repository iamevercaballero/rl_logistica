# =============================================================================
# RL Logística — Template de TEST / STAGING
# Copiar a .env.test (gitignored) y rellenar.
# Usar con: docker compose -f docker-compose.test.yml --env-file .env.test up -d
# =============================================================================

# --- Base de datos PostgreSQL -------------------------------------------------
DB_HOST=db
DB_PORT=5432
DB_USERNAME=rl_test
DB_PASSWORD=                      # openssl rand -base64 32
DB_DATABASE=logistica_palets_test

POSTGRES_USER=rl_test
POSTGRES_PASSWORD=                # debe coincidir con DB_PASSWORD
POSTGRES_DB=logistica_palets_test

# --- TypeORM ------------------------------------------------------------------
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true
DB_LOGGING=false

# --- Auth ---------------------------------------------------------------------
JWT_SECRET=                       # openssl rand -base64 64 (distinto al de prod)
JWT_EXPIRES_IN=8h

# --- Seguridad ----------------------------------------------------------------
CORS_ORIGIN=https://test.tudominio.com
THROTTLE_TTL=60000
THROTTLE_LIMIT=300                # más laxo en test para QA automatizado

# --- Frontend (Vite) ----------------------------------------------------------
VITE_API_URL=https://api-test.tudominio.com/api

# --- Facturación (modo simulación en test) -----------------------------------
EMISOR_RUC=80000000
EMISOR_DV=0
EMISOR_RAZON_SOCIAL=RL SERVICIO LOGISTICO SRL
FACTURA_TIMBRADO=12345678
FACTURA_VIGENCIA=2026-12-31
FACTURA_ESTABLECIMIENTO=001
FACTURA_PUNTO_EXPEDICION=001
SIFEN_URL=                        # vacío = simulación, no toca DNIT real
SIFEN_URL_CONSULTA=

# --- Misc ---------------------------------------------------------------------
NODE_ENV=production               # build optimizado, pero entorno de pruebas
ALLOW_SEED=true                   # en test SÍ se permite cargar datos de prueba
