# =============================================================================
# RL Logística — Template de variables de entorno
# Copiar a .env y rellenar con valores reales. NO commitear .env real.
# =============================================================================

# --- Base de datos PostgreSQL ---------------------------------------------
DB_HOST=db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=cambia_esto_por_un_password_fuerte
DB_DATABASE=logistica_palets

# Cuando corres comandos desde tu máquina (no desde docker), usa el puerto
# expuesto por docker-compose:
#   DB_HOST=localhost
#   DB_PORT=5433

POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia_esto_por_un_password_fuerte
POSTGRES_DB=logistica_palets

# --- TypeORM ------------------------------------------------------------------
# Activá synchronize SOLO en bootstrap inicial sobre DB vacía. Producción: false.
DB_SYNCHRONIZE=false
# Si true, NestJS aplica migrations pendientes al arrancar (recomendado prod).
DB_MIGRATIONS_RUN=true
# Si true, loguea TODAS las queries SQL. Útil en debug, ruidoso en prod.
DB_LOGGING=false

# --- Auth ---------------------------------------------------------------------
# Generar con: openssl rand -base64 64
JWT_SECRET=reemplazar_por_secreto_fuerte
JWT_EXPIRES_IN=8h

# --- Frontend (Vite) ----------------------------------------------------------
VITE_API_URL=http://localhost:3000/api

# --- Facturación electrónica Paraguay (SIFEN) --------------------------------
EMISOR_RUC=80000000
EMISOR_DV=0
EMISOR_RAZON_SOCIAL=RL SERVICIO LOGISTICO SRL
EMISOR_NOMBRE_FANTASIA=RL Logística
EMISOR_DIRECCION=Asunción, Paraguay
EMISOR_RESPONSABLE=Gerente General
FACTURA_TIMBRADO=12345678
FACTURA_VIGENCIA=2026-12-31
FACTURA_ESTABLECIMIENTO=001
FACTURA_PUNTO_EXPEDICION=001
# Dejar vacío para modo simulación
SIFEN_URL=
SIFEN_URL_CONSULTA=

# --- Misc ---------------------------------------------------------------------
NODE_ENV=production
ALLOW_SEED=false
