# =============================================================================
# RL Logística — Template de PRODUCCIÓN
# Copiar a .env.prod (gitignored) y rellenar con valores reales.
# Usar con: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# =============================================================================

# --- Base de datos PostgreSQL -------------------------------------------------
# En prod la DB NO expone puerto al host: el backend la alcanza por red interna.
DB_HOST=db
DB_PORT=5432
DB_USERNAME=rl_prod
DB_PASSWORD=                      # REQUERIDO: openssl rand -base64 32
DB_DATABASE=logistica_palets

POSTGRES_USER=rl_prod
POSTGRES_PASSWORD=                # debe coincidir con DB_PASSWORD
POSTGRES_DB=logistica_palets

# --- TypeORM ------------------------------------------------------------------
DB_SYNCHRONIZE=false              # NUNCA true en producción
DB_MIGRATIONS_RUN=true            # aplica migrations pendientes al arrancar
DB_LOGGING=false

# --- Auth ---------------------------------------------------------------------
JWT_SECRET=                       # REQUERIDO: openssl rand -base64 64
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=               # REQUERIDO: openssl rand -base64 64 (diferente al JWT_SECRET)
JWT_REFRESH_EXPIRES_IN=7d

# --- Logging ------------------------------------------------------------------
LOG_LEVEL=info                    # trace | debug | info | warn | error

# --- Seguridad ----------------------------------------------------------------
# CORS: orígenes permitidos (lista separada por coma). En prod, dominio real.
CORS_ORIGIN=https://app.tudominio.com
# Rate limiting: ventana (ms) y máximo de requests por IP en esa ventana.
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

# --- Redis (cache + WebSocket event bus) -------------------------------------
# En docker-compose.prod.yml el backend pasa REDIS_HOST=redis (servicio interno)
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=                   # si usás Redis protegido con contraseña

# --- Frontend (Vite, inyectado en build) -------------------------------------
VITE_API_URL=https://api.tudominio.com/api
VITE_WS_URL=https://api.tudominio.com

# --- Facturación electrónica Paraguay (SIFEN) --------------------------------
EMISOR_RUC=80000000
EMISOR_DV=0
EMISOR_RAZON_SOCIAL=RL SERVICIO LOGISTICO SRL
EMISOR_NOMBRE_FANTASIA=RL Logística
EMISOR_DIRECCION=Asunción, Paraguay
EMISOR_RESPONSABLE=Gerente General
FACTURA_TIMBRADO=12345678
FACTURA_VIGENCIA=2026-12-31
FACTURA_ESTABLECIMIENTO=001
FACTURA_PUNTO_EXPEDICION=001
SIFEN_URL=                        # endpoint real DNIT (vacío = simulación)
SIFEN_URL_CONSULTA=

# --- Reportes por correo (email digest diario a las 07:00) -------------------
MAIL_ENABLED=false                # cambiar a true + completar SMTP para activar
SMTP_HOST=smtp.gmail.com          # o smtp.office365.com, etc.
SMTP_PORT=587
SMTP_SECURE=false                 # true si usás puerto 465
SMTP_USER=                        # dirección de email del remitente
SMTP_PASS=                        # contraseña o app-password
MAIL_FROM=RL Logística <no-reply@tudominio.com>
MAIL_REPORT_TO=                   # destinatarios separados por coma

# --- Misc ---------------------------------------------------------------------
NODE_ENV=production
ALLOW_SEED=false                  # seed SIEMPRE bloqueado en producción
